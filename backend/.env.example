# Vocrit AI licensing backend — copy to .env and fill in.

# HTTP port the server listens on
PORT=3000

# SQLite database file (relative to backend/ root)
DATABASE_PATH=./vocrit.db

# Money Fusion API credentials
# Get these from https://pay.moneyfusion.net/
MONEY_FUSION_API_KEY=replace-me
MONEY_FUSION_API_URL=https://www.pay.moneyfusion.net/api/checkout
# Optional: URL Money Fusion will call when a payment is confirmed
MONEY_FUSION_WEBHOOK_SECRET=replace-me

# URL the desktop app will poll to check payment status (this backend's public URL)
PUBLIC_BASE_URL=https://api.vocrit.ai

# URL the user will be redirected to after a successful mobile-money payment
CHECKOUT_SUCCESS_URL=https://vocrit.ai/thank-you
CHECKOUT_CANCEL_URL=https://vocrit.ai/payment-cancelled

# Comma-separated list of admin emails automatically granted AdminFree tier
ADMIN_EMAILS=admin@vocrit.ai

# Static master license key that unlocks AdminFree. Must match
# VOCRIT_ADMIN_MASTER_KEY baked into the desktop binary.
ADMIN_MASTER_KEY=VOCRIT-ADMIN-FOREVER-CHANGE-ME

# Annual subscription price in XOF (FCFA)
SUBSCRIPTION_PRICE_XOF=10000
SUBSCRIPTION_CURRENCY=XOF
SUBSCRIPTION_DURATION_DAYS=365
